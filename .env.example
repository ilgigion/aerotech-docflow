# Safe Aerotech Docflow environment example. It contains no real machine data.
# Copy this file to .env only for local development, then replace every
# REPLACE_WITH_* value. Never commit the resulting .env file.
# The preferred Windows machine configuration is config.toml.
DOCFLOW_CONFIG_FILE=C:\ProgramData\Aerotech Docflow\config\config.toml

# Runtime mode. Keep development for tests. Production is fail-closed.
DOCFLOW_ENV=development
DOCFLOW_VERSION=dev
DOCFLOW_HOST=127.0.0.1
DOCFLOW_PORT=8000

# NAPS2
NAPS2_EXECUTABLE=C:\Program Files\NAPS2\NAPS2.Console.exe
NAPS2_PROFILE=REPLACE_WITH_NAPS2_PROFILE_NAME
NAPS2_OUTPUT_ENCODING=cp866

# Scanner temp folder
SCANNER_INCOMING_DIR=C:\AerotechDocflow-Example\incoming
SCANNER_TIMEOUT_SECONDS=180
SCANNER_TIMEOUT_KILL_GRACE_SECONDS=10
SCANNER_VERIFY_PROCESS_EXIT_SECONDS=5
SCANNER_QUARANTINE_FAILED_OUTPUTS=1
SCANNER_FAILED_SCAN_DIR_NAME=_failed_runtime
SCANNER_MIN_PDF_SIZE_BYTES=100
SCANNER_MIN_PDF_PAGES=1
SCANNER_STABLE_CHECKS=2
SCANNER_STABLE_INTERVAL_SECONDS=0.5

# Direct eSCL mode, used only when NAPS2_PROFILE is empty
SCANNER_DRIVER=escl
SCANNER_DEVICE_NAME=REPLACE_WITH_SCANNER_DEVICE_NAME
SCANNER_SOURCE=duplex
SCANNER_DPI=300
SCANNER_PAGE_SIZE=a4
SCANNER_BIT_DEPTH=gray

# Archive
ARCHIVE_ROOT=C:\AerotechDocflow-Example\archive
# Required in production; must exactly match resolved ARCHIVE_ROOT.
DOCFLOW_ARCHIVE_CONFIRMATION=
DOCFLOW_ARCHIVE_ID=
DOCFLOW_ALLOWED_DOC_TYPES=TYPE_A,TYPE_B
DOCFLOW_MIN_DOCUMENT_YEAR=2020
DOCFLOW_MAX_DOCUMENT_YEAR=2030
STORAGE_COPY_BUFFER_SIZE=1048576
STORAGE_KEEP_TEMP_ON_ERROR=0
STORAGE_RESERVATION_STALE_AFTER_SECONDS=1800

# Scanner lock
SCANNER_LOCK_STALE_SECONDS=1800
SCANNER_LOCK_WAIT_TIMEOUT_SECONDS=0
SCANNER_LOCK_RETRY_INTERVAL_SECONDS=0.5
SCANNER_LOCK_ALLOW_STALE_TAKEOVER=1

# Text monthly logs
DOCFLOW_MONTHLY_FILE_LOGS=1
DOCFLOW_LOG_LEVEL=INFO
DOCFLOW_LOG_DIR=C:\AerotechDocflow-Example\logs
DOCFLOW_LOG_MAX_BYTES=52428800
DOCFLOW_LOG_BACKUP_COUNT=5
DOCFLOW_LOG_RETENTION_MONTHS=12

# File idempotency markers
DOCFLOW_IDEMPOTENCY_ENABLED=1
DOCFLOW_IDEMPOTENCY_DIR=C:\AerotechDocflow-Example\idempotency
DOCFLOW_IDEMPOTENCY_STALE_SECONDS=1800

# Incoming cleanup
INCOMING_CLEANUP_QUARANTINE_DIR_NAME=_failed
INCOMING_CLEANUP_MANAGED_PREFIX=PF_
INCOMING_CLEANUP_MANAGED_SUFFIX=.pdf
INCOMING_CLEANUP_MIN_AGE_SECONDS=86400
INCOMING_CLEANUP_SKIP_IF_LOCK_EXISTS=1
INCOMING_CLEANUP_STABLE_CHECKS=2
INCOMING_CLEANUP_STABLE_INTERVAL_SECONDS=0.2
